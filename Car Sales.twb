      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.17okbsh01zc5q310m7mg40vsbr5o].[pcto:usr:Calculation_1003905735491584:qk]&quot;' value='% of Total YTD Total Sales ' />
        </aliases>
      </column>
      <column datatype='string' name='[Body Style]' role='dimension' type='nominal' />
      <column caption='YoY Avg Growth' datatype='real' name='[Calculation_0150409965809664]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1003905746169862]-[YTD AvgPrice (copy)_1003905746460679])/[YTD AvgPrice (copy)_1003905746460679]' />
      </column>
      <column caption='YTD Total Sales' datatype='integer' default-format='c&quot;$ &quot;#,##0,,.00M;-&quot;$ &quot;#,##0,,.00M' name='[Calculation_1003905735491584]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF &#13;&#10;YEAR([Date])= {MAX(YEAR([Date]))}&#13;&#10;THEN&#13;&#10;[Price ($)]&#13;&#10;END)' />
      </column>
      <column caption='YoY Sales Growth' datatype='real' name='[Calculation_1003905737494530]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1003905735491584] - [YTD Total Sales (copy)_1003905737072641])/[YTD Total Sales (copy)_1003905737072641]' />
      </column>
      <column caption='YTD Cars Sales' datatype='integer' name='[Calculation_1003905743003651]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF &#13;&#10;YEAR([Date])= {MAX(YEAR([Date]))}&#13;&#10;THEN&#13;&#10;[Car_id]&#13;&#10;END)' />
      </column>
      <column caption='YoY Cars Sold Growth' datatype='real' name='[Calculation_1003905744175109]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1003905743003651]- [YTD Cars Slaes (copy)_1003905743781892])/[YTD Cars Slaes (copy)_1003905743781892]' />
      </column>
      <column caption='YTD AvgPrice' datatype='real' name='[Calculation_1003905746169862]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1003905735491584]/ [Calculation_1003905743003651]' />
      </column>
      <column caption='Car id' datatype='string' name='[Car_id]' role='dimension' type='nominal' />
      <column datatype='string' name='[Color]' role='dimension' type='nominal' />
      <column caption='Dealer Name' datatype='string' name='[Dealer_Name]' role='dimension' type='nominal' />
      <column caption='Dealer No' datatype='string' name='[Dealer_No]' role='dimension' type='nominal' />
      <column caption='Dealer Region' datatype='string' name='[Dealer_Region]' role='dimension' type='nominal' />
      <column datatype='string' name='[Transmission]' role='dimension' type='nominal' />
      <column caption='PYTD AvgPrice ' datatype='real' name='[YTD AvgPrice (copy)_1003905746460679]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[YTD Total Sales (copy)_1003905737072641] / [YTD Cars Slaes (copy)_1003905743781892]' />
      </column>
      <column caption='PYTD Cars Sales' datatype='integer' name='[YTD Cars Slaes (copy)_1003905743781892]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF &#13;&#10;YEAR([Date])= {MAX(YEAR([Date]))}-1&#13;&#10;THEN&#13;&#10;[Car_id]&#13;&#10;END)' />
      </column>
      <column caption='PYTD Total Sales ' datatype='integer' name='[YTD Total Sales (copy)_1003905737072641]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF &#13;&#10;YEAR([Date])= {MAX(YEAR([Date]))}-1&#13;&#10;THEN&#13;&#10;[Price ($)]&#13;&#10;END)' />
      </column>
